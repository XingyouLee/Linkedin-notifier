# Zeabur single-app deployment env for the Docker service.
CLOUD_DEPLOYMENT=1

# Airflow metadata DB (dedicated to Airflow itself)
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow_user:change-me@your-airflow-db-host:5432/airflow

# Business DB used by DAG tasks
JOBS_DB_URL=postgresql://jobs_user:change-me@your-business-db-host:5432/jobsdb

# Airflow 3 auth / execution API
AIRFLOW__CORE__AUTH_MANAGER=airflow.api_fastapi.auth.managers.simple.simple_auth_manager.SimpleAuthManager
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_USERS=admin:admin
AIRFLOW__CORE__FERNET_KEY=replace-me
AIRFLOW__API__SECRET_KEY=replace-me
AIRFLOW__API_AUTH__JWT_SECRET=replace-me-with-a-long-random-string
AIRFLOW__API__BASE_URL=http://127.0.0.1:8080
AIRFLOW__CORE__EXECUTION_API_SERVER_URL=http://127.0.0.1:8080/execution/

# Profile config inside the image
PROFILE_CONFIG_PATH=/usr/local/airflow/include/user_info/profiles.json

# Scan tuning
SCAN_REQUEST_PAGE_SIZE=10
SCAN_BETWEEN_REQUESTS_MIN_SEC=2
SCAN_BETWEEN_REQUESTS_MAX_SEC=10
SCAN_BETWEEN_TERMS_DELAY_SEC=8.0
SCAN_HTTP_MAX_RETRIES=6
SCAN_HTTP_BASE_DELAY_SEC=2.0
SCAN_HTTP_MAX_DELAY_SEC=60.0
SCAN_HTTP_JITTER_SEC=1.5
SCAN_REQUEST_TIMEOUT_SEC=45

# JD / fitting tuning
JD_WORKER_BATCH_SIZE=3
FITTING_CONCURRENCY=8

# LLM endpoints and API keys
LLM_ENDPOINTS_JSON=[{"name":"998","request_url":"https://your-998-endpoint.example.com/v1/responses","api_key_env":"_998_API_KEY"},{"name":"gmn","request_url":"https://your-gmn-endpoint.example.com/v1/responses","api_key_env":"GMN_API_KEY"},{"name":"yuan","request_url":"https://your-yuan-endpoint.example.com/v1/responses","api_key_env":"YUAN_API_KEY"},{"name":"xcode","request_url":"https://your-xcode-endpoint.example.com/v1/responses","api_key_env":"XCODE_API_KEY"}]
GMN_API_KEY=replace-me
XCODE_API_KEY=replace-me
_998_API_KEY=replace-me
YUAN_API_KEY=replace-me

# Optional legacy single-endpoint fallback (leave blank if using LLM_ENDPOINTS_JSON)
FITTING_REQUEST_URL=
LLM_API_KEY=

# Discord
DISCORD_BOT_TOKEN=replace-me
DISCORD_CHANNEL_ID=
DISCORD_WEBHOOK_URL=
